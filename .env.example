# Локально пусто → apps/server/data
# SERVER_STORAGE_DIR=

# Redis (phase 3+)
# REDIS_URL=redis://localhost:6379

# Production CORS (required when NODE_ENV=production)
# CORS_ORIGIN=https://example.com

# Production: путь к сборке клиента (по умолчанию apps/client/dist)
# CLIENT_DIST_PATH=
