PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/homecraft
MONGODB_TIMEOUT_MS=500

# RAG / embeddings: deterministic local hash vectors in Phase 1
EMBEDDINGS_PROVIDER=local-hash

KB_TOP_K=5
