{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noImplicitAny": false,
    "noEmit": true,
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "@homecraft/ai": ["./packages/ai/src/index.js"],
      "@homecraft/contracts": ["./packages/contracts/src/index.js"],
      "@homecraft/catalog-schema": ["./packages/catalog-schema/src/index.js"]
    },
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "maxNodeModuleJsDepth": 0,
    "noUncheckedSideEffectImports": false,
    "skipLibCheck": true
  },
  "include": ["apps/**/*.js", "apps/**/*.jsx", "apps/**/*.mjs", "apps/**/*.d.ts", "packages/**/*.js"],
  "exclude": ["**/node_modules/**", "apps/client/dist/**", "apps/server/data/**"]
}
