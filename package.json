{
  "name": "homecraft",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "AI-powered furniture design platform — dialog and editor to production-ready BOM.",
  "workspaces": [
    "apps/client",
    "apps/mobile",
    "apps/server",
    "packages/ai",
    "packages/catalog-schema",
    "packages/contracts"
  ],
  "scripts": {
    "build": "npm run build --workspace @homecraft/client",
    "build:deploy": "npm run build",
    "start": "npm run start --workspace @homecraft/server",
    "dev": "concurrently -n server,client -c blue,green \"npm run dev --workspace @homecraft/server\" \"npm run dev --workspace @homecraft/client\"",
    "dev:server": "npm run dev --workspace @homecraft/server",
    "dev:client": "npm run dev --workspace @homecraft/client",
    "dev:mobile": "npm run start --workspace @homecraft/mobile",
    "lint": "eslint .",
    "typecheck": "tsc --project jsconfig.json",
    "test": "npm run test --workspaces --if-present",
    "catalog:index": "npm run catalog:index --workspace @homecraft/server"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "eslint": "^9.28.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.2.0",
    "nodemon": "^3.1.14",
    "typescript": "^7.0.2"
  }
}
